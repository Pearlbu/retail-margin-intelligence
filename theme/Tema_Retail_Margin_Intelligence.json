{
  "name": "Retail Margin Intelligence",
  "dataColors": [
    "#2DD4BF",
    "#3B82F6",
    "#A78BFA",
    "#F59E0B",
    "#F472B6",
    "#34D399",
    "#60A5FA",
    "#FBBF24"
  ],
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "background": "#1C212B",
  "foreground": "#E5E7EB",
  "tableAccent": "#2DD4BF",
  "textClasses": {
    "callout": {
      "fontSize": 30,
      "fontFace": "Segoe UI Semibold",
      "color": "#F9FAFB"
    },
    "title": {
      "fontSize": 13,
      "fontFace": "Segoe UI Semibold",
      "color": "#E5E7EB"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#D1D5DB"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#9CA3AF"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#1C212B" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#2A3140" } },
            "radius": 12
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#000000" } },
            "position": "Outer",
            "preset": "BottomRight"
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#E5E7EB" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#10141B" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#10141B" } },
            "transparency": 0
          }
        ]
      }
    }
  }
}
